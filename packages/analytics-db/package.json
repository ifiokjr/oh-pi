{
  "name": "@ifi/pi-analytics-db",
  "version": "0.1.0",
  "description": "SQLite database layer for Pi analytics with migrations",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js"
    },
    "./migrations": {
      "types": "./dist/migrations.d.ts",
      "import": "./dist/migrations.js"
    }
  },
  "files": [
    "dist",
    "migrations"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:fast": "tsc --build --force",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --build --watch"
  },
  "dependencies": {
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.41.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "drizzle-kit": "^0.30.0",
    "typescript": "^5.7.0"
  }
}
