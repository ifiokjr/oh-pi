{
	"private": true,
	"packageManager": "pnpm@10.30.2",
	"scripts": {
		"build": "pnpm -r --filter @ifi/oh-pi-core --filter @ifi/oh-pi-cli --filter @ifi/pi-web-client --filter @ifi/pi-web-server run build",
		"build:fast": "pnpm -r --filter @ifi/oh-pi-core --filter @ifi/oh-pi-cli --filter @ifi/pi-web-client --filter @ifi/pi-web-server run build:fast",
		"typecheck": "pnpm --filter @ifi/oh-pi-core build && pnpm -r --filter @ifi/oh-pi-ant-colony --filter @ifi/oh-pi-core --filter @ifi/oh-pi-cli --filter @ifi/pi-spec --filter @ifi/pi-web-client --filter @ifi/pi-web-server run typecheck",
		"verify:completion": "pnpm exec vitest run packages/ant-colony/tests/commands.test.ts",
		"security:allowlist": "node ./scripts/security/check-dependency-allowlist.mjs",
		"security:audit:prod": "pnpm audit --prod --audit-level=high",
		"security:audit:dev": "pnpm audit -D --audit-level=high",
		"security:check": "pnpm security:allowlist && pnpm security:audit:prod && pnpm security:audit:dev",
		"test": "vitest run",
		"verify:compiled-tarballs": "node ./scripts/verify-compiled-tarballs.mjs",
		"verify:published-packages": "node ./scripts/verify-published-packages.mjs",
		"lint": "biome check --error-on-warnings .",
		"lint:fix": "biome check --fix .",
		"format": "biome format --write .",
		"check": "biome ci --error-on-warnings ."
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^22.0.0",
		"@typescript/native-preview": "7.0.0-dev.20260305.1",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"pnpm": {
		"overrides": {
			"file-type": "21.3.1",
			"undici": "7.24.0",
			"yauzl@<3.2.1": ">=3.2.1",
			"file-type@>=20.0.0 <=21.3.1": ">=21.3.2",
			"fast-xml-parser": "5.5.6",
			"picomatch": "4.0.4"
		}
	}
}
