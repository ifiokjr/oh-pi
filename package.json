{
	"private": true,
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"build": "pnpm --filter @monopi/core build && pnpm -r --filter=!@monopi/core run build",
		"build:fast": "pnpm --filter @monopi/core run build:fast && pnpm -r --filter=!@monopi/core run build:fast",
		"typecheck": "pnpm --filter @monopi/core build && pnpm -r --filter @monopi/core --filter @monopi/cli --filter @monopi/web-client --filter @monopi/web-server --filter @monopi/db run typecheck",
		"verify:completion": "pnpm exec vitest run packages/monopi__subagents/tests/commands.test.ts",
		"security:allowlist": "node ./scripts/security/check-dependency-allowlist.mjs",
		"security:audit:prod": "node ./scripts/security/run-pnpm-audit.mjs --prod --audit-level=high",
		"security:audit:dev": "node ./scripts/security/run-pnpm-audit.mjs -D --audit-level=high",
		"security:check": "pnpm security:allowlist && pnpm security:audit:prod && pnpm security:audit:dev",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"test:patch-coverage": "pnpm tsx ./scripts/check-patch-coverage.ts --threshold 100 --lcov coverage/lcov.info",
		"bench": "pnpm bench:startup && pnpm bench:runtime && pnpm bench:extensions-render && pnpm bench:live-runtime",
		"bench:startup": "OH_PI_RUN_BENCHMARKS=1 pnpm exec vitest run benchmarks/startup/startup-bench.test.ts",
		"bench:runtime": "OH_PI_RUN_BENCHMARKS=1 pnpm exec vitest run benchmarks/runtime/runtime-bench.test.ts",
		"bench:extensions-render": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./benchmarks/extensions-render-performance.ts",
		"bench:live-runtime": "node --disable-warning=MODULE_TYPELESS_PACKAGE_JSON --experimental-strip-types ./benchmarks/live-runtime-behavior.ts",
		"verify:compiled-tarballs": "node ./scripts/verify-compiled-tarballs.mjs",
		"verify:published-packages": "node ./scripts/verify-published-packages.mjs",
		"verify:pi-compat": "node ./scripts/verify-pi-compat.mjs",
		"pi:switch": "node --experimental-strip-types ./scripts/pi-source-switch.mts",
		"pi:local": "node --experimental-strip-types ./scripts/pi-source-switch.mts local",
		"pi:published": "node --experimental-strip-types ./scripts/pi-source-switch.mts remote",
		"models:refresh-intelligence": "node ./scripts/generate-model-intelligence-snapshot.mjs",
		"mdt": "mdt",
		"docs:dev": "pnpm --filter @monopi/docs dev",
		"docs:build": "pnpm --filter @monopi/docs build",
		"docs:sync": "pnpm --filter @monopi/docs docs:sync",
		"docs:list": "pnpm mdt list",
		"docs:update": "pnpm mdt update",
		"docs:check": "pnpm mdt check",
		"lint": "oxlint --deny-warnings .",
		"lint:fix": "oxlint --fix .",
		"lint:type-aware": "oxlint --deny-warnings --type-aware .",
		"format": "oxfmt --write .",
		"format:check": "oxfmt --check .",
		"check": "pnpm format:check && pnpm lint",
		"change": "mc change",
		"release": "mc release",
		"publish": "mc publish",
		"mc:validate": "mc step:validate",
		"mc:check": "mc check",
		"mc:discover": "mc step:discover --format json"
	},
	"devDependencies": {
		"@earendil-works/pi-agent-core": "0.78.1",
		"@earendil-works/pi-ai": "0.78.1",
		"@earendil-works/pi-coding-agent": "0.78.1",
		"@earendil-works/pi-tui": "0.78.1",
		"@ifi/mdt": "^0.7.0",
		"@types/node": "^22.15.0",
		"@typescript/native-preview": "7.0.0-dev.20260426.1",
		"@vitest/coverage-v8": "^4.1.5",
		"oxfmt": "^0.46.0",
		"oxlint": "^1.61.0",
		"oxlint-tsgolint": "^0.22.0",
		"tsdown": "^0.21.10",
		"tsx": "^4.20.6",
		"vitest": "^4.1.5"
	},
	"engines": {
		"node": ">=20.0.0"
	},
	"packageManager": "pnpm@10.33.0",
	"pi": {
		"extensions": [
			"./packages/monopi__extension-answer/index.ts",
			"./packages/monopi__extension-goal/index.ts",
			"./packages/monopi__extension-todos/index.ts",
			"./packages/monopi__extension-review/index.ts",
			"./packages/monopi__extension-watchdog/index.ts",
			"./packages/monopi__extension-btw/index.ts",
			"./packages/monopi__extension-compact-header/index.ts",
			"./packages/monopi__extension-custom-footer/index.ts",
			"./packages/monopi__extension-external-editor/index.ts",
			"./packages/monopi__extension-git-guard/index.ts",
			"./packages/monopi__extension-scheduler/index.ts",
			"./packages/monopi__extension-shell-format/index.ts",
			"./packages/monopi__extension-tool-metadata/index.ts",
			"./packages/monopi__extension-usage-tracker/index.ts",
			"./packages/monopi__extension-worktree/index.ts",
			"./packages/monopi__background-tasks/index.ts",
			"./packages/monopi__diagnostics/index.ts",
			"./packages/monopi__subagents/index.ts",
			"./packages/monopi__subagents/notify.ts",
			"./packages/monopi__web-remote/index.ts",
			"./packages/monopi__provider-cursor/index.ts",
			"./packages/monopi__provider-ollama/index.ts",
			"./packages/monopi__analytics-extension/index.ts"
		],
		"skills": [
			"./packages/monopi__skills/skills"
		]
	}
}
