{
	"private": true,
	"packageManager": "pnpm@10.30.2",
	"scripts": {
		"build": "pnpm -r --filter @ifi/oh-pi-core --filter @ifi/oh-pi-cli run build",
		"build:fast": "pnpm -r --filter @ifi/oh-pi-core --filter @ifi/oh-pi-cli run build:fast",
		"typecheck": "pnpm -r --filter @ifi/oh-pi-core --filter @ifi/oh-pi-cli run typecheck",
		"test": "vitest run",
		"lint": "biome check . && prettier --check '**/*.md'",
		"lint:fix": "biome check --fix . && prettier --write '**/*.md'",
		"format": "biome format --write . && prettier --write '**/*.md'",
		"check": "biome ci . && prettier --check '**/*.md'"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/node": "^22.0.0",
		"@typescript/native-preview": "7.0.0-dev.20260305.1",
		"prettier": "^3.8.1",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"engines": {
		"node": ">=20.0.0"
	}
}
